{
  "description": "Canonical contract fixtures. pytest asserts the Python side EMITS exactly these shapes; vitest asserts the Worker SERVES each one correctly. Adding a fixture here forces both suites to cover it. og_entries carry per-audience expectations: expect_preview = response for a link-preview crawler UA, expect_human = response for a browser UA ('passthrough' = must reach origin).",
  "entries": [
    {
      "name": "plain redirect",
      "key": "cache:spoo.me:abc1234",
      "value": {
        "type": "redirect",
        "url": "https://example.com/dest",
        "status": 302
      },
      "expect": {
        "status": 302,
        "location": "https://example.com/dest"
      }
    },
    {
      "name": "emoji short code",
      "key": "cache:spoo.me:🚀🚀",
      "value": {
        "type": "redirect",
        "url": "https://example.com/rocket",
        "status": 302
      },
      "expect": {
        "status": 302,
        "location": "https://example.com/rocket"
      }
    },
    {
      "name": "query-string destination survives verbatim",
      "key": "cache:spoo.me:qs1",
      "value": {
        "type": "redirect",
        "url": "https://example.com/p?a=1&b=%20x",
        "status": 302
      },
      "expect": {
        "status": 302,
        "location": "https://example.com/p?a=1&b=%20x"
      }
    }
  ],
  "geo_entries": [
    {
      "name": "geo redirect with country overrides",
      "key": "cache:spoo.me:geo1",
      "value": {
        "type": "geo_redirect",
        "url": "https://example.com/default",
        "status": 302,
        "rules": {
          "IN": "https://example.in/",
          "US": "https://example.com/us"
        }
      },
      "cases": [
        {
          "country": "IN",
          "location": "https://example.in/"
        },
        {
          "country": "US",
          "location": "https://example.com/us"
        },
        {
          "country": "DE",
          "location": "https://example.com/default"
        },
        {
          "country": "XX",
          "location": "https://example.com/default"
        },
        {
          "country": "T1",
          "location": "https://example.com/default"
        },
        {
          "country": null,
          "location": "https://example.com/default"
        }
      ]
    },
    {
      "name": "geo redirect grouped countries share a destination",
      "key": "cache:spoo.me:geo2",
      "value": {
        "type": "geo_redirect",
        "url": "https://example.com/global",
        "status": 302,
        "rules": {
          "DE": "https://eu.example/x",
          "FR": "https://eu.example/x",
          "JP": "https://apac.example/x"
        }
      },
      "cases": [
        {
          "country": "FR",
          "location": "https://eu.example/x"
        },
        {
          "country": "JP",
          "location": "https://apac.example/x"
        },
        {
          "country": "BR",
          "location": "https://example.com/global"
        }
      ]
    }
  ],
  "og_entries": [
    {
      "name": "og_only serves preview bots, humans passthrough",
      "key": "cache:spoo.me:og1",
      "value": {
        "type": "og_only",
        "status": 302,
        "og_html": "<!doctype html><html><head><meta property=\"og:title\" content=\"Custom Card\"></head><body></body></html>"
      },
      "expect_preview": {
        "status": 200,
        "body_contains": "og:title"
      },
      "expect_human": "passthrough"
    },
    {
      "name": "hot og-link: redirect entry with embedded og_html",
      "key": "cache:spoo.me:og2",
      "value": {
        "type": "redirect",
        "url": "https://example.com/dest",
        "status": 302,
        "og_html": "<!doctype html><html><head><meta property=\"og:title\" content=\"Hot Card\"></head><body></body></html>"
      },
      "expect_preview": {
        "status": 200,
        "body_contains": "og:title"
      },
      "expect_human": {
        "status": 302,
        "location": "https://example.com/dest"
      }
    },
    {
      "name": "hot geo og-link: geo_redirect entry with embedded og_html",
      "key": "cache:spoo.me:og3",
      "value": {
        "type": "geo_redirect",
        "url": "https://example.com/default",
        "status": 302,
        "rules": {
          "IN": "https://example.in/"
        },
        "og_html": "<!doctype html><html><head><meta property=\"og:title\" content=\"Geo Card\"></head><body></body></html>"
      },
      "expect_preview": {
        "status": 200,
        "body_contains": "og:title"
      },
      "expect_human": {
        "status": 302,
        "location": "https://example.com/default"
      }
    }
  ],
  "malformed": [
    {
      "name": "unknown type must passthrough, not error",
      "key": "cache:spoo.me:future1",
      "raw": "{\"type\": \"password_form\", \"body\": \"<html></html>\", \"status\": 401}"
    },
    {
      "name": "invalid json must passthrough, not error",
      "key": "cache:spoo.me:broken1",
      "raw": "{not json"
    },
    {
      "name": "geo_redirect without rules must passthrough, not error",
      "key": "cache:spoo.me:georaw1",
      "raw": "{\"type\": \"geo_redirect\", \"url\": \"https://example.com/safe\", \"status\": 302}"
    }
  ]
}
